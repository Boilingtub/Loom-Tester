1756:Drivers/CMSIS/Include/core_cm7.h **** #define _VAL2FLD(field, value)    (((uint32_t)(value) << field ## _Pos) & field ## _Msk)
1757:Drivers/CMSIS/Include/core_cm7.h **** 
1758:Drivers/CMSIS/Include/core_cm7.h **** /**
1759:Drivers/CMSIS/Include/core_cm7.h ****   \brief     Mask and shift a register value to extract a bit filed value.
1760:Drivers/CMSIS/Include/core_cm7.h ****   \param[in] field  Name of the register bit field.
1761:Drivers/CMSIS/Include/core_cm7.h ****   \param[in] value  Value of register. This parameter is interpreted as an uint32_t type.
1762:Drivers/CMSIS/Include/core_cm7.h ****   \return           Masked and shifted bit field value.
1763:Drivers/CMSIS/Include/core_cm7.h **** */
1764:Drivers/CMSIS/Include/core_cm7.h **** #define _FLD2VAL(field, value)    (((uint32_t)(value) & field ## _Msk) >> field ## _Pos)
