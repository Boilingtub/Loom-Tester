2211:Drivers/CMSIS/Include/core_cm7.h **** 
2212:Drivers/CMSIS/Include/core_cm7.h ****   mvfr0 = SCB->MVFR0;
2213:Drivers/CMSIS/Include/core_cm7.h ****   if      ((mvfr0 & (FPU_MVFR0_Single_precision_Msk | FPU_MVFR0_Double_precision_Msk)) == 0x220U)
2214:Drivers/CMSIS/Include/core_cm7.h ****   {
2215:Drivers/CMSIS/Include/core_cm7.h ****     return 2U;           /* Double + Single precision FPU */
2216:Drivers/CMSIS/Include/core_cm7.h ****   }
2217:Drivers/CMSIS/Include/core_cm7.h ****   else if ((mvfr0 & (FPU_MVFR0_Single_precision_Msk | FPU_MVFR0_Double_precision_Msk)) == 0x020U)
2218:Drivers/CMSIS/Include/core_cm7.h ****   {
2219:Drivers/CMSIS/Include/core_cm7.h ****     return 1U;           /* Single precision FPU */
2220:Drivers/CMSIS/Include/core_cm7.h ****   }
2221:Drivers/CMSIS/Include/core_cm7.h ****   else
