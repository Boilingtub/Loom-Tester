2118:Drivers/CMSIS/Include/core_cm7.h ****   uint32_t PreemptPriorityBits;
2119:Drivers/CMSIS/Include/core_cm7.h ****   uint32_t SubPriorityBits;
2120:Drivers/CMSIS/Include/core_cm7.h **** 
2121:Drivers/CMSIS/Include/core_cm7.h ****   PreemptPriorityBits = ((7UL - PriorityGroupTmp) > (uint32_t)(__NVIC_PRIO_BITS)) ? (uint32_t)(__NV
2122:Drivers/CMSIS/Include/core_cm7.h ****   SubPriorityBits     = ((PriorityGroupTmp + (uint32_t)(__NVIC_PRIO_BITS)) < (uint32_t)7UL) ? (uint
2123:Drivers/CMSIS/Include/core_cm7.h **** 
2124:Drivers/CMSIS/Include/core_cm7.h ****   *pPreemptPriority = (Priority >> SubPriorityBits) & (uint32_t)((1UL << (PreemptPriorityBits)) - 1
2125:Drivers/CMSIS/Include/core_cm7.h ****   *pSubPriority     = (Priority                   ) & (uint32_t)((1UL << (SubPriorityBits    )) - 1
2126:Drivers/CMSIS/Include/core_cm7.h **** }
