2206:Drivers/CMSIS/Include/core_cm7.h ****    - \b  2: Double + Single precision FPU
2207:Drivers/CMSIS/Include/core_cm7.h ****  */
2208:Drivers/CMSIS/Include/core_cm7.h **** __STATIC_INLINE uint32_t SCB_GetFPUType(void)
2209:Drivers/CMSIS/Include/core_cm7.h **** {
