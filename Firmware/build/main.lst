 297:Core/Src/main.c **** int process_hex_input(uint8_t* result, uint8_t* size) {
 298:Core/Src/main.c ****     if(rx3_len <= 1) {
 299:Core/Src/main.c ****       #ifdef Debug
 300:Core/Src/main.c ****       do_Tx(&huart3, (uint8_t*)"Input Error (HEX) !\n", 20) ;
 301:Core/Src/main.c ****       #endif
 302:Core/Src/main.c ****       return 1;
 303:Core/Src/main.c ****     }
 304:Core/Src/main.c **** 
 305:Core/Src/main.c ****     uint16_t rx3_clean_len = rx3_len;
 306:Core/Src/main.c ****     uint8_t* rx3_clean_buf = trim_leading(0xFF, rx3_buf, &rx3_clean_len);
 307:Core/Src/main.c **** 
 308:Core/Src/main.c ****     //do_Tx(&huart3, (uint8_t*)rx3_clean_buf, rx3_clean_len); //Since HEX, provides WIERD ASCII
 309:Core/Src/main.c **** 
 310:Core/Src/main.c ****     memset(result,0,*size);
 311:Core/Src/main.c ****     uint8_t copy_len = ((rx3_clean_len) < (*size)) ? (rx3_clean_len) : (*size);
 312:Core/Src/main.c ****     memcpy(result, rx3_clean_buf, copy_len);
 313:Core/Src/main.c ****     *size = copy_len;
 314:Core/Src/main.c ****     return 0;
 315:Core/Src/main.c **** }
