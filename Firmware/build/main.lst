 274:Core/Src/main.c **** int process_ascii_input(char* result, uint8_t size) {
 275:Core/Src/main.c ****     if(rx3_len <= 1) {
 276:Core/Src/main.c ****       #ifdef Debug
 277:Core/Src/main.c ****       do_Tx(&huart3, (uint8_t*)"Input Error (ASCII) !\n", 22);
 278:Core/Src/main.c ****       #endif
 279:Core/Src/main.c ****       return 1;
 280:Core/Src/main.c ****     }
 281:Core/Src/main.c **** 
 282:Core/Src/main.c ****     uint16_t rx3_clean_len = rx3_len;
 283:Core/Src/main.c ****     uint8_t* rx3_clean_buf = trim_leading(' ',rx3_buf, &rx3_clean_len);
 284:Core/Src/main.c **** 
 285:Core/Src/main.c ****     //do_Tx(&huart3, (uint8_t*)rx3_clean_buf, rx3_clean_len);
 286:Core/Src/main.c **** 
 287:Core/Src/main.c ****     uint8_t copy_len = ((rx3_clean_len) < (size)) ? (rx3_clean_len) : (size );
 288:Core/Src/main.c ****     strncpy(result, (char*)rx3_clean_buf, copy_len-1);
 289:Core/Src/main.c ****     result[copy_len-1] = '\0';
 290:Core/Src/main.c ****     return 0;
 291:Core/Src/main.c **** }
 292:Core/Src/main.c **** 
 293:Core/Src/main.c **** int process_hex_input(uint8_t* result, uint8_t* size) {
 294:Core/Src/main.c ****     if(rx3_len <= 1) {
 295:Core/Src/main.c ****       #ifdef Debug
 296:Core/Src/main.c ****       do_Tx(&huart3, (uint8_t*)"Input Error (HEX) !\n", 20) ;
 297:Core/Src/main.c ****       #endif
 298:Core/Src/main.c ****       return 1;
 299:Core/Src/main.c ****     }
 300:Core/Src/main.c **** 
 301:Core/Src/main.c ****     uint16_t rx3_clean_len = rx3_len;
 302:Core/Src/main.c ****     uint8_t* rx3_clean_buf = trim_leading(0xFF, rx3_buf, &rx3_clean_len);
 303:Core/Src/main.c **** 
 304:Core/Src/main.c ****     //do_Tx(&huart3, (uint8_t*)rx3_clean_buf, rx3_clean_len); //Since HEX, provides WIERD ASCII
 305:Core/Src/main.c **** 
 306:Core/Src/main.c ****     memset(result,0,*size);
 307:Core/Src/main.c ****     uint8_t copy_len = ((rx3_clean_len) < (*size)) ? (rx3_clean_len) : (*size);
 308:Core/Src/main.c ****     memcpy(result, rx3_clean_buf, copy_len);
 309:Core/Src/main.c ****     *size = copy_len;
 310:Core/Src/main.c ****     return 0;
 311:Core/Src/main.c **** }
