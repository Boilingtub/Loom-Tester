 278:Core/Src/main.c **** int process_ascii_input(char* result, uint8_t size) {
 279:Core/Src/main.c ****     if(rx3_len <= 1) {
 280:Core/Src/main.c ****       #ifdef Debug
 281:Core/Src/main.c ****       do_Tx(&huart3, (uint8_t*)"Input Error (ASCII) !\n", 22);
 282:Core/Src/main.c ****       #endif
 283:Core/Src/main.c ****       return 1;
 284:Core/Src/main.c ****     }
 285:Core/Src/main.c **** 
 286:Core/Src/main.c ****     uint16_t rx3_clean_len = rx3_len;
 287:Core/Src/main.c ****     uint8_t* rx3_clean_buf = trim_leading(' ',rx3_buf, &rx3_clean_len);
 288:Core/Src/main.c **** 
 289:Core/Src/main.c ****     //do_Tx(&huart3, (uint8_t*)rx3_clean_buf, rx3_clean_len);
 290:Core/Src/main.c **** 
 291:Core/Src/main.c ****     uint8_t copy_len = ((rx3_clean_len) < (size)) ? (rx3_clean_len) : (size );
 292:Core/Src/main.c ****     strncpy(result, (char*)rx3_clean_buf, copy_len-1);
 293:Core/Src/main.c ****     result[copy_len-1] = '\0';
 294:Core/Src/main.c ****     return 0;
 295:Core/Src/main.c **** }
