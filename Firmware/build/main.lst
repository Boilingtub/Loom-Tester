 214:Core/Src/main.c **** int apply_pin_config(uint8_t* confptr, uint8_t len, bool append) {
 215:Core/Src/main.c ****   if(confptr[0] >= len) {
 216:Core/Src/main.c ****     #ifdef Debug
 217:Core/Src/main.c ****     do_Tx(&huart3, (uint8_t*)"impossible pin config\n", 22);
 218:Core/Src/main.c ****     #endif
 219:Core/Src/main.c ****     return 1;
 220:Core/Src/main.c ****   }
 221:Core/Src/main.c ****   #ifdef Debug 
 222:Core/Src/main.c ****     char conn_unit[4] = "";
 223:Core/Src/main.c ****     conn_msg[0] = '\0';
 224:Core/Src/main.c ****   #endif /* if  */
 225:Core/Src/main.c ****   uint8_t output_count = confptr[0];
 226:Core/Src/main.c **** 
 227:Core/Src/main.c ****   if (!append) {
 228:Core/Src/main.c ****     Output_Pins_len = 0;
 229:Core/Src/main.c ****     Input_Pins_len = 0;
 230:Core/Src/main.c ****   }
 231:Core/Src/main.c **** 
 232:Core/Src/main.c ****   for(uint8_t i = 1; i <= output_count; i++) {
 233:Core/Src/main.c ****     if (confptr[i] >= GPIO_PINS_Len) {
 234:Core/Src/main.c ****       #ifdef Debug
 235:Core/Src/main.c ****         do_Tx(&huart3, (uint8_t*)"undefined pin in config !\n", 26);
 236:Core/Src/main.c ****       #endif
 237:Core/Src/main.c ****       return 1;
 238:Core/Src/main.c ****     }
 239:Core/Src/main.c ****     Output_Pins[Output_Pins_len] = Pins[confptr[i]];
 240:Core/Src/main.c ****     #ifdef Debug
 241:Core/Src/main.c ****       snprintf(conn_unit, 4, "%d,",Output_Pins[Output_Pins_len].index);
 242:Core/Src/main.c ****       strcat((char*)conn_msg, conn_unit);
 243:Core/Src/main.c ****     #endif /* ifdef Debug */
 244:Core/Src/main.c ****     Output_Pins_len++; 
 245:Core/Src/main.c ****   }
 246:Core/Src/main.c ****   
 247:Core/Src/main.c ****   strcat((char*)conn_msg, ":");
 248:Core/Src/main.c ****   
 249:Core/Src/main.c ****   for(uint8_t i = output_count+1; i < len; i++) {
 250:Core/Src/main.c ****     if (confptr[i] >= GPIO_PINS_Len) {
 251:Core/Src/main.c ****       #ifdef Debug
 252:Core/Src/main.c ****         do_Tx(&huart3, (uint8_t*)"undefined pin in config !\n", 26);
 253:Core/Src/main.c ****       #endif
 254:Core/Src/main.c ****       return 1;
 255:Core/Src/main.c ****     }
 256:Core/Src/main.c ****     Input_Pins[Input_Pins_len] = Pins[confptr[i]];
 257:Core/Src/main.c ****     #ifdef  Debug
 258:Core/Src/main.c ****       snprintf(conn_unit, 4, "%d,",Input_Pins[Input_Pins_len].index);
 259:Core/Src/main.c ****       strcat((char*)conn_msg, conn_unit);
 260:Core/Src/main.c ****     #endif /* ifdef  DEBUG */
ARM GAS  /tmp/ccVvSPo8.s 			page 6


 261:Core/Src/main.c ****     Input_Pins_len++;
