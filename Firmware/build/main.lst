 268:Core/Src/main.c **** uint8_t* trim_leading(uint8_t thing, uint8_t* org_str, uint16_t* len ) {
 269:Core/Src/main.c ****   uint8_t* str = org_str;
 270:Core/Src/main.c ****   while(*str == thing) {str++; (*len)--;}
