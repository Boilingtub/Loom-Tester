 451:Core/Src/system_stm32h7xx.c **** /**
 452:Core/Src/system_stm32h7xx.c ****   * @brief  Exit Run* mode and Configure the system Power Supply
 453:Core/Src/system_stm32h7xx.c ****   *
 454:Core/Src/system_stm32h7xx.c ****   * @note   This function exits the Run* mode and configures the system power supply
 455:Core/Src/system_stm32h7xx.c ****   *         according to the definition to be used at compilation preprocessing level.
 456:Core/Src/system_stm32h7xx.c ****   *         The application shall set one of the following configuration option:
 457:Core/Src/system_stm32h7xx.c ****   *           - PWR_LDO_SUPPLY
 458:Core/Src/system_stm32h7xx.c ****   *           - PWR_DIRECT_SMPS_SUPPLY
 459:Core/Src/system_stm32h7xx.c ****   *           - PWR_EXTERNAL_SOURCE_SUPPLY
 460:Core/Src/system_stm32h7xx.c ****   *           - PWR_SMPS_1V8_SUPPLIES_LDO
 461:Core/Src/system_stm32h7xx.c ****   *           - PWR_SMPS_2V5_SUPPLIES_LDO
 462:Core/Src/system_stm32h7xx.c ****   *           - PWR_SMPS_1V8_SUPPLIES_EXT_AND_LDO
 463:Core/Src/system_stm32h7xx.c ****   *           - PWR_SMPS_2V5_SUPPLIES_EXT_AND_LDO
 464:Core/Src/system_stm32h7xx.c ****   *           - PWR_SMPS_1V8_SUPPLIES_EXT
 465:Core/Src/system_stm32h7xx.c ****   *           - PWR_SMPS_2V5_SUPPLIES_EXT
 466:Core/Src/system_stm32h7xx.c ****   *
 467:Core/Src/system_stm32h7xx.c ****   * @note   The function modifies the PWR->CR3 register to enable or disable specific
 468:Core/Src/system_stm32h7xx.c ****   *         power supply modes and waits until the voltage level flag is set, indicating
 469:Core/Src/system_stm32h7xx.c ****   *         that the power supply configuration is stable.
 470:Core/Src/system_stm32h7xx.c ****   *
 471:Core/Src/system_stm32h7xx.c ****   * @param  None
 472:Core/Src/system_stm32h7xx.c ****   * @retval None
 473:Core/Src/system_stm32h7xx.c ****   */
